# Appwrite (same project as the Monochrome client)
APPWRITE_ENDPOINT=https://sfo.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=69c700650032a44907ed

# Upstash Redis / Vercel KV REST — copy values from Upstash dashboard (do not commit real tokens)
# The app only reads KV_REST_API_URL + KV_REST_API_TOKEN (see lib/store.ts)
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Optional; not required by this sync-api
# KV_REST_API_READ_ONLY_TOKEN=
# KV_URL= and REDIS_URL= are for other clients; @vercel/kv uses the REST pair above
