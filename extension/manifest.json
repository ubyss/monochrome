{
    "manifest_version": 3,
    "name": "Monochrome Tidal Origin",
    "version": "1.0.0",
    "description": "Adds Origin: https://listen.tidal.com to Tidal CDN requests so audio plays without a proxy",
    "permissions": ["declarativeNetRequest", "scripting", "declarativeNetRequestWithHostAccess"],
    "host_permissions": [
        "*://*.tidal.com/*",
        "*://monochrome.tf/*",
        "*://monochrome.samidy.com/*",
        "*://lossless.wtf/*",
        "*://localhost:*/*"
    ],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "rules",
                "enabled": true,
                "path": "rules.json"
            }
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "*://monochrome.samidy.com/*",
                "*://monochrome.tf/*",
                "*://lossless.wtf/*",
                "*://localhost:*/*"
            ],
            "js": ["content.js"],
            "run_at": "document_start",
            "all_frames": true
        }
    ],
    "icons": {
        "16": "icons/16.png",
        "48": "icons/48.png",
        "128": "icons/128.png"
    },
    "web_accessible_resources": [
        {
            "resources": ["inject.js"],
            "matches": ["*://monochrome.samidy.com/*", "*://monochrome.tf/*", "*://lossless.wtf/*", "*://localhost:*/*"]
        }
    ]
}
